		{
			"name": "1.2.1 Get Professor Course ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Found at least one subject with courses', function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('subjects');",
							"    pm.expect(jsonData.subjects.length).to.be.above(0);",
							"    var firstSubject = jsonData.subjects[0];",
							"    pm.expect(firstSubject.courses.length).to.be.above(0);",
							"    var courseId = firstSubject.courses[0].id;",
							"    pm.collectionVariables.set('setupCourseId', courseId);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "{{professorToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/subjects",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"subjects"
					]
				}
			}
		},
		{
			"name": "1.2.2 Create Student User (if missing)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Student created or already exists', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([204, 400, 409]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "{{professorToken}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"udg-student1\",\n    \"fullName\": \"UdG Student 1\",\n    \"email\": \"{{studentEmail}}\",\n    \"password\": \"{{studentPassword}}\",\n    \"userType\": \"STUDENT\",\n    \"courseId\": {{setupCourseId}}\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/users/register",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"users",
						"register"
					]
				}
			}
		},
