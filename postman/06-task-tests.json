{
	"name": "6. Task Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "6.1.1 Get Task - Member",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404 (or 400 if task not created)', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
									"});",
									"",
									"pm.test('Response contains task data (if found)', function () {",
									"    if (pm.response.code === 200) {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('task');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/tasks/{{testTaskId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"tasks",
								"{{testTaskId}}"
							]
						}
					}
				},
				{
					"name": "6.1.2 Edit Task - Member",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404 (or 400 if task not created)', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
									"});",
									"",
									"pm.test('Task was updated (if found)', function () {",
									"    if (pm.response.code === 200) {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('description');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"description\": \"Updated description {{$timestamp}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/tasks/{{testTaskId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"tasks",
								"{{testTaskId}}"
							]
						}
					}
				},
				{
					"name": "6.1.3 Create Subtask - Professor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200, 400, or 404', function () {",
