{
	"name": "5. Project Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "5.1.1 Create Project - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200, 400, or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
									"});",
									"",
									"pm.test('Response contains project ID or error', function () {",
									"    var jsonData = pm.response.json();",
									"    if (pm.response.code === 200) {",
									"        pm.expect(jsonData).to.have.property('id');",
									"        pm.collectionVariables.set('testProjectId', jsonData.id);",
									"    } else {",
									"        // 400/404 is acceptable for test course not having enrolled members",
									"        pm.expect(jsonData).to.have.property('message');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Project {{$timestamp}}\",\n    \"members\": [\"{{studentEmail}}\", \"{{professorEmail}}\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/courses/{{testCourseId}}/projects",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"courses",
								"{{testCourseId}}",
								"projects"
							]
						}
					}
				},
				{
					"name": "5.1.2 Get Project - Student Member",
