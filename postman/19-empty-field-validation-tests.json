					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"\",\n    \"workspaceId\": {{udgWorkspaceId}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/subjects",
