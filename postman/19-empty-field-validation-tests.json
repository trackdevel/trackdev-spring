						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Empty subject name should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 409]);",
									"});"
								],
								"type": "text/javascript"
							}
