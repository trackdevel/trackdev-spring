{
	"name": "16. User View Authorization Tests",
	"item": [
		{
			"name": "ADMIN Access",
			"item": [
				{
					"name": "16.1.1 Admin can view any user by ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('SECURITY: Admin can view any user', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('email');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/uuid/{{studentId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"uuid",
								"{{studentId}}"
							]
						}
					}
				},
				{
					"name": "16.1.2 Admin can view any user by email",
