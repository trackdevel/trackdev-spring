					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Note: This test uses student2Id which is from a DIFFERENT project",
									"// Expected: 400/403 since they are not teammates",
									"// The test name is misleading - needs proper teammate setup",
									"pm.test('Status code is 200 or 400 (test setup uses different-project student)', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
									"});",
									"",
									"pm.test('Response structure is valid', function () {",
									"    var jsonData = pm.response.json();",
									"    // Either has id (success) or message (error)",
									"    var hasId = jsonData.hasOwnProperty('id');",
									"    var hasMessage = jsonData.hasOwnProperty('message');",
									"    pm.expect(hasId || hasMessage).to.be.true;",
									"});"
								],
