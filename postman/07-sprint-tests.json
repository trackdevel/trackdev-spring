{
	"name": "7. Sprint Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "7.1.1 Get Sprint - Member",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200, 400, or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
									"});",
									"",
									"pm.test('Response contains sprint data (if found)', function () {",
									"    if (pm.response.code === 200) {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('name');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/sprints/{{testSprintId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"sprints",
								"{{testSprintId}}"
							]
						}
					}
				},
				{
					"name": "7.1.2 Edit Sprint - Professor",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200, 400, or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404]);",
									"});",
									"",
									"pm.test('Sprint was updated (if found)', function () {",
									"    if (pm.response.code === 200) {",
									"        var jsonData = pm.response.json();",
									"        pm.expect(jsonData).to.have.property('name');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "{{professorToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Sprint {{$timestamp}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/sprints/{{testSprintId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"sprints",
								"{{testSprintId}}"
							]
						}
					}
				},
				{
					"name": "7.1.3 Get Sprint History",
