{
	"name": "8. Cleanup",
	"item": [
		{
			"name": "8.1 Delete Subtask - Creator",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 204 or 404 (resource may not exist)', function () {",
							"    pm.expect(pm.response.code).to.be.oneOf([204, 404]);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "{{studentToken}}"
					}
				],
				"url": {
					"raw": "{{baseUrl}}/tasks/{{testSubtaskId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"tasks",
						"{{testSubtaskId}}"
					]
				}
			}
		},
