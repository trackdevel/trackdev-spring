{
	"name": "3. User Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "3.1.1 Get All Users - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Response is an object with users array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('users');",
									"    pm.expect(jsonData.users).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "3.1.2 Check Admin Status - Admin User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Admin check returns true', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.admin).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/checker/admin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"checker",
								"admin"
							]
						}
					}
				},
				{
					"name": "3.1.3 Check Admin Status - Student User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Admin check returns false for student', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.admin).to.be.false;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/checker/admin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"checker",
								"admin"
							]
						}
					}
				}
			]
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "3.2.1 Get All Users - Student (Forbidden)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 403 (Forbidden)', function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"",
									"pm.test('Student cannot access all users', function () {",
									"    // Access denied for non-admin",
									"    pm.expect(pm.response.code).to.equal(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "3.2.2 Get User - Non-existent",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 404', function () {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users/nonexistent@email.com",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"nonexistent@email.com"
							]
						}
					}
				},
				{
					"name": "3.2.3 Edit Other User - Student (Forbidden)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 403 (Forbidden)', function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"",
									"pm.test('Student cannot edit other users', function () {",
									"    pm.expect(pm.response.code).to.equal(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"Hacked Name\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{adminId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users",
								"{{adminId}}"
							]
						}
					}
				}
			]
		}
	]
}
