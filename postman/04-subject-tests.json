{
	"name": "4. Subject Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "4.1.1 Create Subject - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Response contains subject ID', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.collectionVariables.set('testSubjectId', jsonData.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test Subject {{$timestamp}}\",\n    \"acronym\": \"TS{{$randomInt}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/subjects",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects"
							]
						}
					}
				},
				{
					"name": "4.1.2 Get Subject - Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Response contains subject data', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('name');",
									"    pm.expect(jsonData).to.have.property('acronym');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/subjects/{{testSubjectId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects",
								"{{testSubjectId}}"
							]
						}
					}
				},
				{
					"name": "4.1.3 Create Course in Subject",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 or 404', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
									"});",
									"",
									"pm.test('Response contains course ID', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.collectionVariables.set('testCourseId', jsonData.id);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"startYear\": 2024\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/subjects/{{testSubjectId}}/courses",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects",
								"{{testSubjectId}}",
								"courses"
							]
						}
					}
				}
			]
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "4.2.1 Create Subject - Student (Forbidden)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 403 (Forbidden)', function () {",
									"    pm.response.to.have.status(403);",
									"});",
									"",
									"pm.test('Student cannot create subjects', function () {",
									"    pm.expect(pm.response.code).to.equal(403);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Hacked Subject\",\n    \"acronym\": \"HACK\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/subjects",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects"
							]
						}
					}
				},
				{
					"name": "4.2.2 Get Subject - Non-existent",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 404', function () {",
									"    pm.response.to.have.status(404);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/subjects/99999",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects",
								"99999"
							]
						}
					}
				},
				{
					"name": "4.2.3 Get Subject - Student (Unauthorized)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code indicates unauthorized or bad request', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404]);",
									"});",
									"",
									"pm.test('Student cannot view subjects they do not own', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([400, 401, 403, 404]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{studentToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/subjects/{{testSubjectId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"subjects",
								"{{testSubjectId}}"
							]
						}
					}
				}
			]
		}
	]
}
