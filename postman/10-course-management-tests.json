{
	"name": "10. Course Management Tests",
	"item": [
		{
			"name": "Happy Path",
			"item": [
				{
					"name": "10.1.1 Get Courses - Admin (all courses)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains courses array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('courses');",
									"    pm.expect(jsonData.courses).to.be.an('array');",
									"});",
									"",
									"pm.test('Admin can see courses from all workspaces', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.courses.length).to.be.greaterThan(0);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "{{adminToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/courses",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"courses"
							]
						}
					}
				},
