{
	"name": "17. JWT Security Tests",
	"item": [
		{
			"name": "Token Manipulation",
			"item": [
				{
					"name": "17.1.1 Malformed JWT - Missing parts",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: Malformed JWT should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});",
									"",
									"pm.test('Should not expose sensitive error details', function () {",
									"    var responseText = pm.response.text();",
									"    pm.expect(responseText.toLowerCase()).to.not.include('stacktrace');",
									"    pm.expect(responseText.toLowerCase()).to.not.include('exception');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer onlyonepart"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/self",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"self"
							]
						}
					}
				},
				{
					"name": "17.1.2 Malformed JWT - Invalid base64",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: Invalid base64 JWT should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer not.valid.base64!!!"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "17.1.3 JWT with tampered payload",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: Tampered JWT should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhZG1pbkB0cmFja2Rldi5jb20iLCJyb2xlIjoiQURNSU4ifQ.tampered_signature"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "17.1.4 JWT with none algorithm attack",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Attack vector: JWT with alg=none to bypass signature verification",
									"pm.test('SECURITY: None algorithm attack should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});",
									"",
									"pm.test('Should not grant access with none algorithm', function () {",
									"    pm.expect(pm.response.code).to.not.equal(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJzdWIiOiJhZG1pbkB0cmFja2Rldi5jb20iLCJyb2xlIjoiQURNSU4ifQ."
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "17.1.5 Empty Authorization header",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: Empty auth header should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": ""
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "17.1.6 Bearer without token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: Bearer without token should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer "
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				},
				{
					"name": "17.1.7 SQL in Authorization header",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('SECURITY: SQL injection in auth should be rejected', function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
									"});",
									"",
									"pm.test('Should not expose database errors', function () {",
									"    var responseText = pm.response.text().toLowerCase();",
									"    pm.expect(responseText).to.not.include('sql');",
									"    pm.expect(responseText).to.not.include('query');",
									"    pm.expect(responseText).to.not.include('syntax');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer ' OR '1'='1"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/users",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"users"
							]
						}
					}
				}
			]
		}
	]
}
